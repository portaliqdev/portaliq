# Copy to .env.local for local dev; set these in Vercel Project Settings for prod.

# Server-only secrets (runtime)
CFBD_API_KEY=
GEMINI_API_KEY=

# Neon Postgres
DATABASE_URL=              # pooled (-pooler) connection — app runtime
DATABASE_URL_UNPOOLED=     # direct connection — migrations + ingest scripts only

# Public backend selectors — MUST be present at BUILD time on Vercel (inlined)
NEXT_PUBLIC_DATA_BACKEND=postgres
NEXT_PUBLIC_AI_BACKEND=gemini
